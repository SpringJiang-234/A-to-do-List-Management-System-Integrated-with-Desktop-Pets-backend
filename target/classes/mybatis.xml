<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>
    <!-- 1. 全局配置设置 -->
    <settings>
        <!-- 日志配置 -->
        <setting name="logImpl" value="LOG4J2"/>
        <setting name="logPrefix" value="[MyBatis] "/>

        <!-- 命名规则配置 -->
        <setting name="mapUnderscoreToCamelCase" value="true"/>
        <!-- 下划线自动转驼峰 -->
        <setting name="localCacheScope" value="SESSION"/>
        <!-- 本地缓存作用域 -->

        <!-- 性能优化配置 -->
        <setting name="lazyLoadingEnabled" value="true"/>
        <!-- 开启延迟加载 -->
        <setting name="aggressiveLazyLoading" value="false"/>
        <!-- 按需加载关联对象 -->
        <setting name="multipleResultSetsEnabled" value="true"/>
        <!-- 允许单条SQL返回多结果集 -->
        <setting name="useColumnLabel" value="true"/>
        <!-- 使用列标签代替列名 -->

        <!-- 执行器配置 -->
        <setting name="defaultExecutorType" value="REUSE"/>
        <!-- 重用执行器 -->

        <!-- 安全性配置 -->
        <setting name="callSettersOnNulls" value="true"/>
        <!-- 当返回行的某个列值为null时，仍然调用setter方法 -->
        <setting name="jdbcTypeForNull" value="NULL"/>
        <!-- 未指定jdbcType时的null值处理方式 -->

        <!-- 超时设置 -->
        <setting name="defaultStatementTimeout" value="30"/>
        <!-- SQL执行超时时间（秒） -->

        <!-- 结果集获取大小 -->
        <setting name="defaultFetchSize" value="100"/>
        <!-- 结果集获取大小 -->
    </settings>

    <!--
        2. 类型别名配置
        扫描指定的包：在Mapper文件中的resultType中可以只写类名，而无需带上包名
     -->
    <typeAliases>
        <package name="com.backend.domain.entity"/>
        <!-- 实体类包别名 -->
        <package name="com.backend.domain.vo"/>
        <!-- VO类包别名 -->
        <package name="com.backend.domain.dto"/>
        <!-- DTO类包别名 -->
        <package name="com.backend.domain.query"/>
    </typeAliases>

    <!-- 3. 类型处理器配置 -->
    <typeHandlers>
        <!-- Java 8 日期时间类型处理器 -->
        <typeHandler handler="org.apache.ibatis.type.LocalDateTypeHandler" jdbcType="DATE" javaType="java.time.LocalDate"/>
        <typeHandler handler="org.apache.ibatis.type.LocalDateTimeTypeHandler" jdbcType="TIMESTAMP" javaType="java.time.LocalDateTime"/>
        <typeHandler handler="org.apache.ibatis.type.LocalTimeTypeHandler" jdbcType="TIME" javaType="java.time.LocalTime"/>
        <typeHandler handler="org.apache.ibatis.type.OffsetDateTimeTypeHandler" jdbcType="TIMESTAMP_WITH_TIMEZONE" javaType="java.time.OffsetDateTime"/>

        <!-- 基本类型处理器 -->
        <typeHandler handler="org.apache.ibatis.type.ByteTypeHandler" jdbcType="TINYINT" javaType="java.lang.Byte"/>
        <typeHandler handler="org.apache.ibatis.type.ShortTypeHandler" jdbcType="SMALLINT" javaType="java.lang.Short"/>

        <!-- 集合类型处理器 -->
        <typeHandler handler="org.apache.ibatis.type.ArrayTypeHandler" jdbcType="ARRAY"/>

        <!-- JSON类型处理器（如果项目中使用JSON数据类型） -->
        <!-- 注意：使用JSON处理器需要引入相应依赖 -->
        <!-- <typeHandler handler="org.apache.ibatis.type.JsonTypeHandler" jdbcType="JSON"/> -->
    </typeHandlers>

    <!-- 4. 插件配置 -->
    <plugins>
        <!-- 分页插件配置 -->
        <plugin interceptor="com.github.pagehelper.PageInterceptor">
            <property name="helperDialect" value="mysql"/>
            <!-- 指定数据库方言 -->
            <property name="reasonable" value="true"/>
            <!-- 启用合理化分页，页码超出范围会自动处理 -->

            <property name="params" value="pageNum=pageNum;pageSize=pageSize;count=countSql;reasonable=reasonable;pageSizeZero=pageSizeZero"/>
            <!-- 分页参数映射 -->
            <property name="pageSizeZero" value="true"/>
            <!-- 当pageSize=0时返回全部结果 -->
        </plugin>

        <!-- 可以添加其他插件，如性能监控插件等 -->
        <!-- <plugin interceptor="com.example.MyPerformanceInterceptor"/> -->
    </plugins>

</configuration>